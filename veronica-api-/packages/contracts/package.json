{
  "name": "@veronica/contracts",
  "version": "1.0.0",
  "type": "module",
  "description": "Shared zod schemas and TypeScript types for the Veronica API and web client.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
