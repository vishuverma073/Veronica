# ─── REQUIRED FOR ONLINE ORDERS (production) ───────────────────────────────
# Site/admin also needs DATABASE_URL + JWT_ADMIN_SECRET (see below).
#
# Customer phone login — without MSG91, OTP is never sent in production.
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_TEMPLATE_ID=
#
# Payment — use rzp_live_* keys at launch (rzp_test_* for staging only).
# Register webhook: POST https://<api-host>/webhooks/razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
#
# Production only:
# NODE_ENV=production
# CORS_ORIGINS=https://yourdomain.com
# STOREFRONT_URL=https://yourdomain.com
# ENABLE_DEV_AUTH_BYPASS=   ← must be UNSET in production

# ─── Core (site + admin + checkout) ────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/veronica
PORT=8787
LOG_LEVEL=info
NODE_ENV=development
# Extra allowed CORS origins (comma-separated) for credentialed browser
# requests. localhost, 127.0.0.1, and private LAN IPs (192.168.x.x, etc.) are
# allowed automatically OUTSIDE production; in production only these origins
# are accepted, e.g. https://veronicaindia.com
CORS_ORIGINS=
# Local-only auth/payment shortcuts: OTP code echoed in the send response,
# OTP rate-limit skipped, and the mock checkout signature accepted. Set to "1"
# for local dev ONLY. MUST be left unset in production (and is ignored unless
# NODE_ENV is not "production"). See src/lib/dev-bypass.ts.
ENABLE_DEV_AUTH_BYPASS=
# Admin session signing secret. Generate via: openssl rand -hex 32
JWT_ADMIN_SECRET=replace-with-openssl-rand-hex-32-output

# ─── OPTIONAL — add after launch ───────────────────────────────────────────
# Image uploads (admin product photos):
# Dashboard → Settings → API. Requires a public-read bucket named "product-images".
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Customer-facing storefront origin (order tracking links in email/SMS).
STOREFRONT_URL=https://veronicaindia.com

# Customer auth JWTs — required for checkout login. Generate: openssl rand -hex 32
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
# JWT_ISSUER=veronica-api  # optional, defaults to veronica-api

# MSG91 order confirmation SMS (optional — logs if unset):
MSG91_ORDER_TEMPLATE_ID=

# Upstash Redis (optional — in-memory fallback when unset):
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Inngest async jobs (optional):
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Resend order email (optional — logs if unset):
RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@veronicaindia.com

# ─── Observability (Phase 5) ────────────────────────────────────────────────
# All optional. Unset = that sink is skipped (Sentry no-ops, Axiom logs to
# stdout only, Slack alerts are dropped). Caching uses the Upstash vars above.

# Sentry error tracking. DSN from Sentry → Project → Settings → Client Keys.
SENTRY_DSN=
# Release tag for Sentry + logs (set by CI to the deployed commit SHA).
GIT_SHA=

# Axiom structured logs. Axiom → Settings → API tokens, and a dataset name.
AXIOM_DATASET=
AXIOM_TOKEN=

# Slack #alerts incoming webhook (Slack → Apps → Incoming Webhooks).
SLACK_WEBHOOK_URL=

# Failure drill (Phase 5): set to 1 to expose GET /test-error, which throws so
# you can verify Sentry/Axiom/Slack fire. Keep UNSET in production.
ENABLE_TEST_ERROR=
