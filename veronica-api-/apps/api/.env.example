DATABASE_URL=postgresql://postgres:postgres@localhost:5432/veronica
PORT=8787
LOG_LEVEL=info
NODE_ENV=development
# Extra allowed CORS origins (comma-separated) for credentialed browser
# requests. localhost/127.0.0.1 are allowed automatically OUTSIDE production;
# in production only these origins are accepted, e.g. https://veronicaindia.com
CORS_ORIGINS=
# Local-only auth/payment shortcuts: OTP code echoed in the send response,
# OTP rate-limit skipped, and the mock checkout signature accepted. Set to "1"
# for local dev ONLY. MUST be left unset in production (and is ignored unless
# NODE_ENV is not "production"). See src/lib/dev-bypass.ts.
ENABLE_DEV_AUTH_BYPASS=
# Admin session signing secret. Generate via: openssl rand -hex 32
JWT_ADMIN_SECRET=replace-with-openssl-rand-hex-32-output

# Image uploads (Task 1.8). Supabase project URL + service_role key (NOT anon).
# Dashboard → Settings → API. Requires a public-read bucket named "product-images".
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# MSG91 SMS OTP (Phase 3). Optional — leave unset to use stub mode (OTP logged
# to the server console). MSG91 dashboard → API → Auth Key; Sender ID (6 chars,
# TRAI-approved); Template ID (approved DLT OTP template).
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_TEMPLATE_ID=
# MSG91 Flow template id for transactional order SMS (order confirmed + tracking
# link). Optional — unset = stub mode (the SMS is logged, not sent). The
# DLT-approved template must map ##var1## → order number, ##var2## → tracking URL.
MSG91_ORDER_TEMPLATE_ID=

# Customer-facing storefront origin used to build the order tracking links sent
# in the confirmation email + SMS (e.g. https://veronicaindia.com/orders/VE...).
STOREFRONT_URL=https://veronicaindia.com

# Customer auth JWTs (Phase 3). Generate each via: openssl rand -hex 32
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
# JWT_ISSUER=veronica-api  # optional, defaults to veronica-api

# Upstash Redis for OTP rate limiting (Phase 3). Optional — in-memory fallback
# when unset. Upstash console → REST API → URL + Token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Razorpay checkout (Phase 4). Leave unset to run in STUB MODE (dummy data) —
# checkout works end-to-end without a real Razorpay account: orders are faked
# locally and signatures verify against a built-in dummy secret. To use a real
# test account, fill these from Razorpay dashboard → Settings → API Keys (test
# mode, format rzp_test_xxx / rzp_live_xxx) and → Webhooks (the webhook secret).
# Dummy values below are illustrative only — they trigger stub mode regardless.
RAZORPAY_KEY_ID=rzp_test_DUMMYKEYID0001
RAZORPAY_KEY_SECRET=dummyrzpsecret0000000000
RAZORPAY_WEBHOOK_SECRET=dummywebhooksecret000000

# Inngest async jobs (Phase 4). Optional. Locally run `npx inngest-cli@latest dev`
# (no keys needed). For Inngest Cloud, set these from the Inngest dashboard.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Resend order-confirmation email (Phase 4). Optional — when unset, the email is
# logged instead of sent. RESEND_FROM_EMAIL must be on a Resend-verified domain.
RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@veronicaindia.com

# ─── Observability (Phase 5) ────────────────────────────────────────────────
# All optional. Unset = that sink is skipped (Sentry no-ops, Axiom logs to
# stdout only, Slack alerts are dropped). Caching uses the Upstash vars above.

# Sentry error tracking. DSN from Sentry → Project → Settings → Client Keys.
SENTRY_DSN=
# Release tag for Sentry + logs (set by CI to the deployed commit SHA).
GIT_SHA=

# Axiom structured logs. Axiom → Settings → API tokens, and a dataset name.
AXIOM_DATASET=
AXIOM_TOKEN=

# Slack #alerts incoming webhook (Slack → Apps → Incoming Webhooks).
SLACK_WEBHOOK_URL=

# Failure drill (Phase 5): set to 1 to expose GET /test-error, which throws so
# you can verify Sentry/Axiom/Slack fire. Keep UNSET in production.
ENABLE_TEST_ERROR=
